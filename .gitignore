# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Test / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Secrets: private keys never get committed ---
# The cashier/ledger SIGNING key is secret. The PUBLIC key is committed so
# the standalone verifier can validate the chain (see SPEC acceptance #10).
*_private.pem
*.key
sentinel_slice/keys/*_private.pem

# --- Runtime artifacts ---
# Serving window: per-order output dirs the chef writes and the diner reads.
# These are ephemeral by design (SPEC claim 3) and must never be committed.
sentinel_slice/window/orders/
# Scratch tempdirs if any land in-tree.
*.tmp/
tmp/
# Console runtime: materialized active policy + the default policy-history db.
sentinel_slice/console/active_policies/
policy_history.db
drill-*.db
drill-*-win/
# Personal permissions file written by the consumer permissions editor.
sentinel_permissions.json
# Operator-created (no-code) capabilities written by the menu builder.
sentinel_slice/capabilities_custom/

# NOTE: ledger.db is intentionally NOT ignored. The "definition of done"
# requires committing a real run's ledger.db alongside verify_ledger.py output.

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Console dev admin private keys (generated each run by sentinel-console without --admins)
console_dev_admins/
